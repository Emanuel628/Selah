{
  "expo": {
    "name": "Selah",
    "slug": "selah",
    "version": "1.0.0",
    "scheme": "selah",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#091a18"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
